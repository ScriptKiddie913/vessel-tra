{
  "version": 2,
  "buildCommand": "pip install -r requirements.txt",
  "outputDirectory": "ui3",
  "functions": {
    "api/index.py": {
      "runtime": "python3.9",
      "maxDuration": 30
    }
  },
  "routes": [
    { "src": "/ws",          "dest": "/api/index.py" },
    { "src": "/api/(.*)",    "dest": "/api/index.py" },
    { "src": "/app.js",      "dest": "/app.js" },
    { "src": "/(.*)",        "dest": "/$1" }
  ]
}
