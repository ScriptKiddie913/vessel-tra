{
  "builds": [
    {
      "src": "main.py",
      "use": "@vercel/python",
      "config": {
        "maxLambdaSize": "50mb",
        "includeFiles": [
          "static/**",
          "static_data.py"
        ]
      }
    }
  ],
  "rewrites": [
    { "source": "/api/(.*)", "destination": "/main.py" },
    { "source": "/(.*)",     "destination": "/main.py" }
  ],
  "env": {
    "VERCEL": "1"
  }
}
